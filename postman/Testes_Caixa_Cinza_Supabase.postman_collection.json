						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"senhaerrada\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/auth/v1/token?grant_type=password",
					"host": ["{{base_url}}"],
					"path": ["auth", "v1", "token"],
					"query": [
						{
							"key": "grant_type",
							"value": "password"
						}
					]
				},
				"description": "Teste de login com senha incorreta. Espera-se Status 400 e mensagem de erro de autenticação."
			},
			"response": []
		},
		{
